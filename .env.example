# Copy this file to `.env` and fill in your values. `.env` is gitignored.
# Get a free key (500 req/month) at https://the-odds-api.com/
ODDS_API_KEY=
# Optional: path to a pre-trained model bundle (.joblib). If unset, the app
# auto-detects the newest file under .hooplytics_cache/models/. Train one with:
#   python -m hooplytics.cli train
HOOPLYTICS_PRETRAINED_BUNDLE=
